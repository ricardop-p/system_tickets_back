PORT=8007
JWT_SECRET=change_me

# En deploy dentro de Dockploy usa la URL interna de PostgreSQL.
# Ejemplo:
# DATABASE_URL=postgresql://usuario:password@nombre-servicio-postgres:5432/nombre_db
DATABASE_URL=

# Si tu proveedor exige SSL, activa estas variables.
DB_SSL=false
DB_SSL_REJECT_UNAUTHORIZED=false

# Timeouts para evitar que Cloudflare termine en 524 si la DB no responde.
DB_CONNECTION_TIMEOUT_MS=5000
DB_QUERY_TIMEOUT_MS=5000

# Alternativa si no usas DATABASE_URL:
# DB_USER=
# DB_HOST=
# DB_NAME=
# DB_PASSWORD=
# DB_PORT=5432
